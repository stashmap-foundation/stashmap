{
    "parser": "@typescript-eslint/parser",
    "env": {
        "browser": true,
        "es6": true,
        "jest/globals": true
    },
    "extends": [
      "plugin:@typescript-eslint/recommended", "plugin:@typescript-eslint/recommended-requiring-type-checking",
      "airbnb", 
      "plugin:prettier/recommended", 
      "plugin:functional/external-typescript-recommended",
      "plugin:functional/no-mutations",
      "plugin:functional/no-other-paradigms",
      "plugin:testing-library/react"
    ],
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly"
    },
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "ecmaVersion": 2018,
        "sourceType": "module",
        "project": "./tsconfig.json"
    },
    "plugins": [
        "@typescript-eslint",
        "prettier",
        "react",
        "jest",
        "functional",
        "testing-library"
    ],
    "settings": { 
      "import/resolver": { 
        "node": { 
          "extensions": [
            ".js", 
            ".jsx",
            ".ts", 
            ".tsx"
          ] 
        } 
      } 
    },
    "rules": {
        "react/jsx-filename-extension": [1, { "extensions": [".js", ".jsx", ".ts", "tsx"] }],
        "react/prop-types": 0,
        "@typescript-eslint/camelcase": 0,
        "@typescript-eslint/no-explicit-any": 2,
        "@typescript-eslint/prefer-readonly-parameter-types": 0,
        "@typescript-eslint/explicit-function-return-type": [1, { "allowExpressions": true }],
        "import/no-extraneous-dependencies": ["error", {"devDependencies": ["**/*.test.ts", "**/*.test.tsx", "**/*.test.js", "**/testutils/**"]}],
        "functional/no-mixed-type": 0,
        "functional/prefer-readonly-type": 0,
        "functional/prefer-immutable-types": 0,
        "functional/type-declaration-immutability": 0,
        "functional/no-mixed-types": 0,
        "import/prefer-default-export": 0,
        "import/extensions": 0,
        "no-undef": 0,
        "no-use-before-define": "off",
        "no-unused-vars": 0,
        "no-shadow": 0,
        "@typescript-eslint/no-unused-vars": 1,
        "@typescript-eslint/no-shadow": 1,
        "@typescript-eslint/no-use-before-define": ["error"],
        "@typescript-eslint/no-misused-promises": 0,
        "react/require-default-props": 0,
        "@typescript-eslint/no-floating-promises": 0,
        "@typescript-eslint/unbound-method": 0,
        "@typescript-eslint/no-unnecessary-type-assertion": 0,
        "react/jsx-no-constructed-context-values": 0,
        "react/jsx-no-bind": 0,
        "react/jsx-no-useless-fragment": 0,
        "react/function-component-definition": 0,
        "react/no-unstable-nested-components": 0
    },
    "overrides": [
        {
          "files": ["src/{graph,rows,session,planner,infra}/**/*.{ts,tsx,js,jsx}"],
          "rules": {
            "import/no-restricted-paths": [
              "error",
              {
                "zones": [
                  {
                    "target": "./src/graph",
                    "from": "./src/rows",
                    "message": "graph must not import rows."
                  },
                  {
                    "target": "./src/graph",
                    "from": "./src/session",
                    "message": "graph must not import session."
                  },
                  {
                    "target": "./src/graph",
                    "from": "./src/planner",
                    "message": "graph must not import planner."
                  },
                  {
                    "target": "./src/graph",
                    "from": "./src/infra",
                    "message": "graph must not import infra."
                  },
                  {
                    "target": "./src/rows",
                    "from": "./src/session",
                    "message": "rows must not import session."
                  },
                  {
                    "target": "./src/rows",
                    "from": "./src/planner",
                    "message": "rows must not import planner."
                  },
                  {
                    "target": "./src/rows",
                    "from": "./src/infra",
                    "message": "rows must not import infra."
                  },
                  {
                    "target": "./src/session",
                    "from": "./src/rows",
                    "message": "session must not import rows."
                  },
                  {
                    "target": "./src/session",
                    "from": "./src/graph",
                    "message": "session must not import graph."
                  },
                  {
                    "target": "./src/session",
                    "from": "./src/planner",
                    "message": "session must not import planner."
                  },
                  {
                    "target": "./src/session",
                    "from": "./src/infra",
                    "message": "session must not import infra."
                  },
                  {
                    "target": "./src/planner",
                    "from": "./src/infra",
                    "message": "planner must not import infra."
                  },
                  {
                    "target": "./src/graph",
                    "from": "./src/surface",
                    "message": "graph must not import surface."
                  },
                  {
                    "target": "./src/rows",
                    "from": "./src/surface",
                    "message": "rows must not import surface."
                  },
                  {
                    "target": "./src/session",
                    "from": "./src/surface",
                    "message": "session must not import surface."
                  },
                  {
                    "target": "./src/planner",
                    "from": "./src/surface",
                    "message": "planner must not import surface."
                  },
                  {
                    "target": "./src/infra",
                    "from": "./src/surface",
                    "message": "infra must not import surface."
                  }
                ]
              }
            ]
          }
        },
        {
          "files": ["src/**/*.{ts,tsx}"],
          "excludedFiles": [
            "src/semanticProjection.ts",
            "src/semanticNavigation.ts",
            "src/navigationUrl.ts",
            "src/NavigationStateContext.tsx",
            "src/ViewContext.tsx",
            "src/markdownDocument.tsx",
            "src/buildReferenceRow.ts",
            "src/treeTraversal.ts",
            "src/LoadSearchData.tsx",
            "src/dataQuery.tsx",
            "src/planner.tsx"
          ],
          "rules": {
            "no-restricted-imports": [
              "error",
              {
                "paths": [
                  {
                    "name": "./semanticProjection",
                    "message": "Semantic projection helpers are restricted to semantic projection and navigation boundary files."
                  },
                  {
                    "name": "../semanticProjection",
                    "message": "Semantic projection helpers are restricted to semantic projection and navigation boundary files."
                  },
                  {
                    "name": "./semanticNavigation",
                    "message": "Semantic navigation helpers are restricted to navigation boundary files."
                  },
                  {
                    "name": "../semanticNavigation",
                    "message": "Semantic navigation helpers are restricted to navigation boundary files."
                  }
                ]
              }
            ]
          }
        },
        {
          "files": ["*.test.tsx", "*.test.ts", "setupTests.js", "setupProxy.js", "**/testutils/*.tsx"],
          "rules": {
            "@typescript-eslint/no-unsafe-member-access": 0,
            "@typescript-eslint/ban-types": 0,
            "@typescript-eslint/no-unsafe-assignment": 0,
            "@typescript-eslint/no-unsafe-call": 0,
            "@typescript-eslint/no-unsafe-return": 0,
            "@typescript-eslint/no-unsafe-argument": 0,
            "@typescript-eslint/restrict-template-expressions": 0,
            "testing-library/no-wait-for-multiple-assertions": 0,
            "testing-library/no-wait-for-side-effects": 0,
            "testing-library/prefer-user-event": ["error", { "allowedMethods": ["click"]}],
            "testing-library/no-manual-cleanup": 0,
            "prettier/prettier": ["error", { "endOfLine": "auto" }]
          }
      },
        {
          "files": ["src/{graph,rows,session,planner,infra}/**/*.{ts,tsx,js,jsx}"],
          "rules": {
            "no-restricted-imports": [
              "error",
              {
                "paths": [
                {
                  "name": "react",
                  "message": "React imports are only allowed in surface."
                }
              ]
            }
          ],
          "no-restricted-globals": [
            "error",
            {
              "name": "window",
              "message": "Browser globals are only allowed in surface."
            },
            {
              "name": "document",
              "message": "Browser globals are only allowed in surface."
            },
            {
              "name": "localStorage",
              "message": "Browser globals are only allowed in surface."
            }
          ]
        }
      },
      {
        "files": ["src/surface/shared/**/*.{ts,tsx,js,jsx}"],
        "rules": {
          "import/no-restricted-paths": [
            "error",
            {
              "zones": [
                {
                  "target": "./src/surface/shared",
                  "from": "./src/surface/app-shell",
                  "message": "surface/shared must not import app-shell."
                },
                {
                  "target": "./src/surface/shared",
                  "from": "./src/surface/workspace",
                  "message": "surface/shared must not import workspace."
                }
              ]
            }
          ]
        }
      },
      {
        "files": ["src/infra/**/*.{ts,tsx,js,jsx}"],
        "excludedFiles": ["src/infra/cli/**/*.{ts,tsx,js,jsx}"],
        "rules": {
          "import/no-restricted-paths": [
            "error",
            {
              "zones": [
                {
                  "target": "./src/infra",
                  "from": "./src/planner",
                  "message": "infra must not import planner."
                },
                {
                  "target": "./src/infra",
                  "from": "./src/rows",
                  "message": "infra must not import rows."
                },
                {
                  "target": "./src/infra",
                  "from": "./src/session",
                  "message": "infra must not import session."
                }
              ]
            }
          ],
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "../graph/*",
                    "../../graph/*",
                    "!../graph/public",
                    "!../../graph/public"
                  ],
                  "message": "infra must import graph through graph/public."
                }
              ]
            }
          ]
        }
      },
      {
        "files": ["src/infra/cli/**/*.{ts,tsx,js,jsx}"],
        "rules": {
          "import/no-restricted-paths": [
            "error",
            {
              "zones": [
                {
                  "target": "./src/infra/cli",
                  "from": "./src/planner/session",
                  "message": "cli must not import planner/session. Use planner/core or graph-safe planner APIs."
                },
                {
                  "target": "./src/infra/cli",
                  "from": "./src/rows",
                  "message": "cli must not import rows."
                },
                {
                  "target": "./src/infra/cli",
                  "from": "./src/session",
                  "message": "cli must not import session."
                },
                {
                  "target": "./src/infra/cli",
                  "from": "./src/surface",
                  "message": "cli must not import surface."
                }
              ]
            }
          ],
          "no-restricted-imports": [
            "error",
            {
              "patterns": [
                {
                  "group": [
                    "../../planner/session",
                    "../../planner/session/*",
                    "../planner/session",
                    "../planner/session/*",
                    "./session",
                    "./session/*"
                  ],
                  "message": "cli must not import planner/session. Use planner/core or graph-safe planner APIs."
                },
                {
                  "group": [
                    "../graph/*",
                    "../../graph/*",
                    "!../graph/public",
                    "!../../graph/public"
                  ],
                  "message": "infra must import graph through graph/public."
                }
              ]
            }
          ]
        }
      },
      {
        "files": ["src/planner/core/**/*.{ts,tsx,js,jsx}"],
        "rules": {
          "import/no-restricted-paths": [
            "error",
            {
              "zones": [
                {
                  "target": "./src/planner/core",
                  "from": "./src/planner/session",
                  "message": "planner/core must not import planner/session."
                },
                {
                  "target": "./src/planner/core",
                  "from": "./src/session",
                  "message": "planner/core must not import session."
                },
                {
                  "target": "./src/planner/core",
                  "from": "./src/rows",
                  "message": "planner/core must not import rows."
                }
              ]
            }
          ]
        }
      }
    ]
}
